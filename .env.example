# Copy this file to .env and fill in your values.
# Never commit .env to git.

# Required: Anthropic API key
ANTHROPIC_API_KEY=sk-ant-...

# Postgres connection (defaults to docker-compose.yml credentials if not set)
DATABASE_URL=postgresql://assistant:assistant@localhost:5432/assistant

# Optional: single-user auth token for the FastAPI layer (Phase 5+)
# API_TOKEN=your-secret-token-here

# Todoist personal API token
# Get it from: https://app.todoist.com/app/settings/integrations/developer
# TODOIST_API_TOKEN=your-todoist-token-here

# Home Assistant
# HASS_URL=http://homeassistant.local:8123
# HASS_TOKEN=your-long-lived-token  (Profile → Security → Long-Lived Access Tokens)

# Your local timezone for calendar events (IANA format).
# Default is UTC if not set.
# TIMEZONE=America/Toronto

# Spotify (for music playback control across all Spotify Connect devices)
# 1. Create a free app at https://developer.spotify.com/dashboard
# 2. Add redirect URI: http://localhost:8888/callback
# 3. Copy Client ID and Client Secret below
# SPOTIFY_CLIENT_ID=your-client-id
# SPOTIFY_CLIENT_SECRET=your-client-secret
# SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# Web search via Tavily (free tier: 1 000 searches/month)
# Sign up at https://tavily.com, then copy your API key below.
# TAVILY_API_KEY=tvly-...
